[run]
source =
    scripts/iso/
    scripts/pipeline/
omit =
    scripts/archive/**
    */conftest.py
    */tests/*

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
    \.\.\.
    def main\(
    parser\.add_argument
    args = parser\.parse_args
fail_under = 80
