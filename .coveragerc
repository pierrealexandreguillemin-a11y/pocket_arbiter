[run]
source =
    scripts/iso/
    scripts/pipeline/
omit =
    scripts/archive/**
    scripts/pipeline/reformat_sft_data.py
    scripts/pipeline/eval_rag_pipeline.py
    scripts/pipeline/gen_answers_api.py
    scripts/pipeline/generate_contexts.py
    scripts/pipeline/precompute_retrieval.py
    scripts/pipeline/sweep_synthetic.py
    scripts/pipeline/extract.py
    */conftest.py
    */tests/*

[report]
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
    \.\.\.
    def main\(
    parser\.add_argument
    args = parser\.parse_args
fail_under = 80
