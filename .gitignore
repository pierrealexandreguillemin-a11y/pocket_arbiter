# Arbitre Échecs RAG - .gitignore

# =============================================================================
# ANDROID
# =============================================================================

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# Android Studio
.idea/
*.iml
local.properties
.DS_Store

# Generated files
app/build/
app/release/

# Signing
*.jks
*.keystore

# Proguard
proguard/

# =============================================================================
# PYTHON
# =============================================================================

# Virtual environment
venv/
.venv/
env/
.env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution
dist/
build/
*.egg-info/

# =============================================================================
# CORPUS & MODELS (LARGE FILES)
# =============================================================================

# PDF sources (à gérer via Git LFS ou séparément)
corpus/fr/**/*.pdf
corpus/intl/**/*.pdf

# Generated indexes (trop volumineux pour Git)
*.index
*.faiss
*.npy
*.bin

# Generated chunks JSON (regenerable via pipeline)
corpus/processed/chunks_*.json
corpus/processed/tables_*.json
corpus/processed/docling_*/

# Annales data (regenerable - see docs/specs/GOLD_STANDARD_V6_ANNALES.md)
corpus/processed/annales_all/
corpus/raw/annales/
data/evaluation/annales/
data/evaluation/gs_validation/

# Models (binaires à télécharger séparément)
models/*.gguf
models/*.tflite
models/*.onnx
models/*.bin
!models/model_card.json
*.gguf
*.tflite
*.onnx

# SQLite databases
*.db
*.sqlite
*.sqlite3

# Large eval response files (>1MB, kept locally for comparison)
*_responses.jsonl
human_eval_34q_full.jsonl

# =============================================================================
# IDE & EDITORS
# =============================================================================

# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# Vim
*.swp
*.swo
*~

# =============================================================================
# OS
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# =============================================================================
# LOGS & TEMP
# =============================================================================

*.log
logs/
tmp/
temp/
cache/
tmpclaude-*

# =============================================================================
# TESTS
# =============================================================================

# Coverage
.coverage
htmlcov/
coverage.xml
*.cover
coverage_report.txt
.pytest_cache/

# =============================================================================
# DVC (Data Version Control)
# =============================================================================
# Cache DVC local
.dvc/cache
.dvc/tmp
.dvc/config.local

# Fichiers trackés par DVC (les .dvc sont dans Git, pas les données)
# Note: les fichiers .dvc DOIVENT être commités
.env

# =============================================================================
# MODEL TRAINING (temporary, large)
# =============================================================================
model_download/
models/embeddinggemma-*/
models/*.jsonl
tmp_kaggle_*/
# Kaggle dataset-generation: large generated JSONL (uploaded via Kaggle CLI, not git)
kaggle/dataset-generation/corpus_paragraphs.jsonl
kaggle/dataset-generation/reading_tasks.jsonl
nul

# Report JSON (regenerable)
corpus/processed/*.report.json
corpus/processed/*.ids.json
# Backup and temp files
tests/data/*.bak
tests/data/*_backup*.json
tests/data/questions_to_reformulate.json
tests/data/reformulation_batch.json
# GS Generation intermediates
data/gs_generation/questions_raw.json
data/gs_generation/questions_enriched.json
data/gs_generation/snapshots/
# Archived benchmarks (moved to data/archive/benchmarks_v8/)
data/archive/benchmarks_v8/
kaggle/model-gemma-270m/
models/kaggle-output/
models/kaggle-sft-output/
models/kaggle-sft-v2-output/
models/kaggle-sft-v3-output/
models/kaggle-tapt-v2-output/

# Kaggle checkpoints (large model weights, uploaded via Kaggle CLI)
kaggle/tapt-checkpoint/model.safetensors
kaggle/tapt-checkpoint/tokenizer.json
kaggle/sft-checkpoint/model.safetensors
kaggle/sft-checkpoint/tokenizer.json
kaggle/eval-data/corpus_v2_fr.db
kaggle/eval-data/gold_standard_annales_fr_v8_adversarial.json
kaggle/dataset-generation/reading_tasks_v2.jsonl
models/kaggle-tapt-sweep-output/
models/kaggle-tapt-v3-sweep-output/

# Phase A/B generation outputs (large JSONL + unsloth cache)
models/kaggle-gen-questions-output/
models/kaggle-gen-answers-output-s1/
models/kaggle-gen-answers-output-s2/

# Dataset uploads (uploaded via Kaggle CLI, not git)
kaggle/dataset-gen-questions-v5/questions_v5.jsonl
kaggle/dataset-tapt-ep1/model.safetensors
kaggle/dataset-tapt-ep1/tokenizer.json
kaggle/dataset-sft-v5/sft_train_v5.jsonl

# SFT v5 output (future, DVC tracked)
models/kaggle-sft-v5-output/

# SFT v5 checkpoints (uploaded to Kaggle, too large for git)
kaggle/sft-v5-checkpoints/checkpoint-*/

# SFT v5 1B local artifacts (large model files + Unsloth cache)
data/benchmarks/sft_v5_1b/unsloth_compiled_cache/
data/benchmarks/sft_v5_1b/gemma-1b-sft-v5/
data/benchmarks/sft_v5_1b/gemma-1b-sft-v5-merged/

# Large retrieval precompute files (DVC or Kaggle only)
data/benchmarks/eval_v5/retrieval_contexts_v5b.jsonl
kaggle/eval-data/retrieval_contexts_v5b.jsonl
kaggle/model-gemma-1b/
tmp_kaggle/
